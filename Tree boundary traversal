class Solution:
    
    def isLeaf(self, node):
        return node.left is None and node.right is None
    
    def addLeft(self, root, res):
        cur = root.left
        while cur:
            if not self.isLeaf(cur):
                res.append(cur.data)
            if cur.left:
                cur = cur.left
            else:
                cur = cur.right
    
    def addLeaves(self, root, res):
        if self.isLeaf(root):
            res.append(root.data)
            return
        
        if root.left:
            self.addLeaves(root.left, res)
        if root.right:
            self.addLeaves(root.right, res)
    
    def addRight(self, root, res):
        cur = root.right
        temp = []
        
        while cur:
            if not self.isLeaf(cur):
                temp.append(cur.data)
            
            if cur.right:
                cur = cur.right
            else:
                cur = cur.left
        
        while temp:
            res.append(temp.pop())
    
    def boundaryTraversal(self, root):
        res = []
        
        if root is None:
            return res
        
        if not self.isLeaf(root):
            res.append(root.data)
        
        self.addLeft(root, res)
        self.addLeaves(root, res)
        self.addRight(root, res)
        
        return res
        
