class Solution:
    def leftView(self, root):
        if root is None:
            return []
        
        result = []
        queue = [root]
        
        while queue:
            n = len(queue)
            
            for i in range(n):
                node = queue.pop(0)
                
                if i == 0:
                    result.append(node.data)
                
                if node.left:
                    queue.append(node.left)
                if node.right:
                    queue.append(node.right)
        
        return result
