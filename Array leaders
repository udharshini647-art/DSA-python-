class Solution:
    def leaders(self, arr):
        n = len(arr)
        result = []
        
        max_right = arr[-1]
        result.append(max_right)
        
        for i in range(n-2, -1, -1):
            if arr[i] >= max_right:
                max_right = arr[i]
                result.append(arr[i])
        
        result.reverse()
        return result
